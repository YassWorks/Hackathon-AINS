# PWA Specific .gitignore

# Dependencies
node_modules/
.pnpm-debug.log*

# Build output
dist/
build/

# Environment variables
.env
.env.local
.env.development.local
.env.production.local

# Cache directories
.cache/
.vite/

# Generated PWA files
sw.js.map
workbox-*.js
workbox-*.js.map

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Coverage reports
coverage/

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp