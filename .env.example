# Backend Environment Variables
FASTAPI_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# External API Keys
CLAIMBUSTER_API_KEY=your_claimbuster_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Database Configuration (if using external DB)
DATABASE_URL=postgresql://user:password@localhost:5432/ains_db

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-domain.com

# Security
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-key

# Azure Configuration
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string
AZURE_CONTAINER_NAME=ains-uploads

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=INFO
